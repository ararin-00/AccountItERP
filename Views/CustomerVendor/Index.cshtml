@model List<AccountItERP.Models.CustomerVendor>

@{
    ViewData["Title"] = "Customer/Vendor Management";
}

@section Styles {
    <link rel="stylesheet" href="~/css/dashboard.css" />
}

<div class="user-management-page">

    <div class="page-title d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2>Customer & Vendor Management</h2>
            <p>Manage customer and vendor records.</p>
        </div>

        <button type="button"
                class="btn btn-primary px-4"
                data-bs-toggle="modal"
                data-bs-target="#createCustomerVendorModal">
            + Add Record
        </button>
    </div>

  <div class="dashboard-card">

    <form asp-action="Index"
          method="get"
          class="row g-3 mb-4 align-items-center">

        <div class="col-md-9">
            <input type="text"
                   name="search"
                   value="@ViewBag.Search"
                   class="form-control"
                   placeholder="Search customer/vendor name..." />
        </div>

        <div class="col-md-3 d-flex gap-2">
            <button type="submit"
                    class="btn btn-primary flex-fill">
                Search
            </button>

            @if (!string.IsNullOrWhiteSpace(ViewBag.Search))
            {
                <a asp-action="Index"
                   class="btn btn-outline-secondary">
                    Clear
                </a>
            }
        </div>

    </form>

        <div class="table-responsive">
            <table class="table align-middle user-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Type</th>
                        <th>Contact Number</th>
                        <th>Email</th>
                        <th>Address</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <strong>@item.Name</strong>
                            </td>

                            <td>
                                @if (item.Type == "Customer")
                                {
                                    <span class="customer-badge">Customer</span>
                                }
                                else
                                {
                                    <span class="vendor-badge">Vendor</span>
                                }
                            </td>

                            <td>@item.ContactNumber</td>
                            <td>@item.Email</td>
                            <td>@item.Address</td>

                            <td>
                                <div class="d-flex justify-content-end gap-2">
                                    <button type="button"
                                            class="btn btn-outline-primary btn-sm px-3"
                                            data-bs-toggle="modal"
                                            data-bs-target="#editCustomerVendorModal-@item.CustomerVendorID">
                                        Edit
                                    </button>

                                    <a href="#"
                                    class="btn btn-outline-danger btn-sm px-3 delete-btn"
                                    data-url="@Url.Action("Delete", new { id = item.CustomerVendorID })">
                                        Delete
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>

            </table>
        </div>

        @if (ViewBag.TotalPages > 1)
        {
            <div class="pagination-wrapper">
                <div class="pagination-info">
                    Page @ViewBag.CurrentPage of @ViewBag.TotalPages
                </div>

                <nav>
                    <ul class="pagination custom-pagination mb-0">

                        <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@(ViewBag.CurrentPage - 1)"
                               asp-route-search="@ViewBag.Search">
                                Previous
                            </a>
                        </li>

                        @for (int i = 1; i <= ViewBag.TotalPages; i++)
                        {
                            <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-page="@i"
                                   asp-route-search="@ViewBag.Search">
                                    @i
                                </a>
                            </li>
                        }

                        <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@(ViewBag.CurrentPage + 1)"
                               asp-route-search="@ViewBag.Search">
                                Next
                            </a>
                        </li>

                    </ul>
                </nav>
            </div>
        }

    </div>

</div>

<!-- CREATE MODAL -->
<div class="modal fade"
     id="createCustomerVendorModal"
     tabindex="-1"
     aria-labelledby="createCustomerVendorModalLabel"
     aria-hidden="true">

    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content custom-modal">

            <form asp-action="Create" method="post" class="confirm-form" data-confirm-type="create">
                @Html.AntiForgeryToken()

                <div class="modal-header">
                    <div>
                        <h5 class="modal-title" id="createCustomerVendorModalLabel">
                            Add Customer/Vendor
                        </h5>
                        <p class="modal-subtitle">
                            Create a new customer or vendor record.
                        </p>
                    </div>

                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal"
                            aria-label="Close">
                    </button>
                </div>

                <div class="modal-body">

                    <div class="mb-3">
                        <label class="form-label fw-bold">Name</label>
                        <input type="text"
                               name="Name"
                               class="form-control"
                               placeholder="Enter name"
                               required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Type</label>
                        <select name="Type" class="form-select" required>
                            <option value="">Select type</option>
                            <option value="Customer">Customer</option>
                            <option value="Vendor">Vendor</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Contact Number</label>
                        <input type="text"
                               name="ContactNumber"
                               class="form-control"
                               placeholder="Enter contact number" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Email</label>
                        <input type="email"
                               name="Email"
                               class="form-control"
                               placeholder="Enter email address" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Address</label>
                        <textarea name="Address"
                                  class="form-control"
                                  rows="3"
                                  placeholder="Enter address"></textarea>
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="button"
                            class="btn btn-outline-primary px-4"
                            data-bs-dismiss="modal">
                        Cancel
                    </button>

                    <button type="submit"
                            class="btn btn-primary px-4">
                        Save Record
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

<!-- EDIT MODALS - OUTSIDE TABLE -->
@foreach (var item in Model)
{
    <div class="modal fade"
         id="editCustomerVendorModal-@item.CustomerVendorID"
         tabindex="-1"
         aria-labelledby="editCustomerVendorModalLabel-@item.CustomerVendorID"
         aria-hidden="true">

        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content custom-modal">

                <form asp-action="Edit"
                method="post"
                class="confirm-form"
                data-confirm-type="edit">
                    @Html.AntiForgeryToken()

                    <input type="hidden" name="CustomerVendorID" value="@item.CustomerVendorID" />

                    <div class="modal-header">
                        <div>
                            <h5 class="modal-title" id="editCustomerVendorModalLabel-@item.CustomerVendorID">
                                Edit Customer/Vendor
                            </h5>
                            <p class="modal-subtitle">
                                Update this customer or vendor record.
                            </p>
                        </div>

                        <button type="button"
                                class="btn-close"
                                data-bs-dismiss="modal"
                                aria-label="Close">
                        </button>
                    </div>

                    <div class="modal-body">

                        <div class="mb-3">
                            <label class="form-label fw-bold">Name</label>
                            <input type="text"
                                   name="Name"
                                   value="@item.Name"
                                   class="form-control"
                                   required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Type</label>
                            <select name="Type" class="form-select" required>
                                <option value="Customer" selected="@(item.Type == "Customer")">Customer</option>
                                <option value="Vendor" selected="@(item.Type == "Vendor")">Vendor</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Contact Number</label>
                            <input type="text"
                                   name="ContactNumber"
                                   value="@item.ContactNumber"
                                   class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Email</label>
                            <input type="email"
                                   name="Email"
                                   value="@item.Email"
                                   class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Address</label>
                            <textarea name="Address"
                                      class="form-control"
                                      rows="3">@item.Address</textarea>
                        </div>

                    </div>

                    <div class="modal-footer">
                        <button type="button"
                                class="btn btn-outline-primary px-4"
                                data-bs-dismiss="modal">
                            Cancel
                        </button>

                        <button type="submit"
                                class="btn btn-primary px-4">
                            Save Changes
                        </button>
                    </div>

                </form>

            </div>
        </div>
    </div>
}